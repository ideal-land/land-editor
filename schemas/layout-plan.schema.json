{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/layout-plan.schema.json",
  "title": "LayoutPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sceneId",
    "mapSize",
    "anchors",
    "pathSegments",
    "zoneBounds",
    "placements",
    "navigation"
  ],
  "properties": {
    "sceneId": {
      "type": "string"
    },
    "mapSize": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        }
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "x",
          "y",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "y": {
            "type": "integer"
          },
          "kind": {
            "type": "string"
          }
        }
      }
    },
    "pathSegments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "points",
          "width"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "points": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "x",
                "y"
              ],
              "additionalProperties": false,
              "properties": {
                "x": {
                  "type": "integer"
                },
                "y": {
                  "type": "integer"
                }
              }
            }
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "material": {
            "type": "string"
          }
        }
      }
    },
    "zoneBounds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "zoneId",
          "x",
          "y",
          "width",
          "height"
        ],
        "properties": {
          "zoneId": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "y": {
            "type": "integer"
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "placements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "id",
          "x",
          "y"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "y": {
            "type": "integer"
          },
          "rotation": {
            "type": "integer"
          },
          "zoneId": {
            "type": "string"
          }
        }
      }
    },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "walkableRectangles",
        "spawnCandidates"
      ],
      "properties": {
        "walkableRectangles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "x",
              "y",
              "width",
              "height"
            ],
            "properties": {
              "x": {
                "type": "integer"
              },
              "y": {
                "type": "integer"
              },
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              }
            }
          }
        },
        "spawnCandidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "x",
              "y"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "x": {
                "type": "integer"
              },
              "y": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  }
}
