{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/generation-report.schema.json",
  "title": "GenerationReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runId",
    "sceneId",
    "status",
    "scores",
    "checks",
    "artifacts"
  ],
  "properties": {
    "runId": {
      "type": "string"
    },
    "sceneId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "warning",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "playability",
        "layout",
        "visualBalance"
      ],
      "properties": {
        "playability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "layout": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "visualBalance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "result",
          "message"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "warning",
              "blocker"
            ]
          },
          "message": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "repairActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
